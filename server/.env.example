# PP-StructureV3 网关后端环境变量示例
# 复制为 .env 并填入真实值，切勿提交 .env 到 git

AI_STUDIO_API_URL=https://aistudio.baidu.com/serving/online/v1/xxx
AI_STUDIO_ACCESS_TOKEN=<your-token-here>

# 服务配置
APP_HOST=0.0.0.0
APP_PORT=8900
APP_LOG_LEVEL=info

# AI Studio 请求超时（秒）
AI_STUDIO_TIMEOUT=60

# 最大上传文件大小（字节），默认 20MB
MAX_UPLOAD_SIZE=20971520
